APP_NAME=Shopla
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://shopla.com.br
APP_FORCE_HTTPS=true
APP_PORT=127.0.0.1:8088

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR
APP_FAKER_LOCALE=pt_BR

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=warning

DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=shopla
DB_USERNAME=shopla
DB_PASSWORD=troque-esta-senha

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database
CACHE_STORE=database

MAIL_MAILER=log
MAIL_FROM_ADDRESS="contato@seudominio.com"
MAIL_FROM_NAME="${APP_NAME}"

RUN_MIGRATIONS=true

ADMIN_EMAILS=

ASAAS_ACCESS_TOKEN=
ASAAS_BASE_URL=https://api-sandbox.asaas.com/v3
ASAAS_CHECKOUT_URL=https://asaas.com/checkoutSession/show?id=
ASAAS_WEBHOOK_TOKEN=
ASAAS_USER_AGENT="${APP_NAME}"
ASAAS_CHECKOUT_EXPIRATION_MINUTES=120

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"
SHOPLA_WHATSAPP=

CLOUDFLARED_TOKEN=

PLAN_PLUS_PRICE=6.99
PLAN_PLUS_CYCLE=MONTHLY
PLAN_PLUS_ANNUAL_CYCLE=YEARLY
PLAN_PRO_PRICE=12.99
PLAN_PRO_CYCLE=MONTHLY
PLAN_PRO_ANNUAL_CYCLE=YEARLY
PLAN_PREMIUM_PRICE=22.99
PLAN_PREMIUM_CYCLE=MONTHLY
PLAN_PREMIUM_ANNUAL_CYCLE=YEARLY
PLAN_ANNUAL_DISCOUNT_PERCENT=10

VITE_APP_NAME="${APP_NAME}"
